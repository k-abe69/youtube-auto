[
  {
    "scene_id": "scene_01",
    "start_sec": 0.0,
    "end_sec": 5.39,
    "text": "イケメンの親切は\\N信じられるのに\\N“キモい男の親切”は\\N警戒されるのはなぜ？",
    "type": "main_title"
  },
  {
    "scene_id": "scene_02_center",
    "start_sec": 5.39,
    "end_sec": 7.92,
    "text": "見た目で判断されるのは\n0.1秒以内",
    "type": "title_center"
  },
  {
    "scene_id": "scene_02_top",
    "start_sec": 7.92,
    "end_sec": 17.87,
    "text": "見た目で判断されるのは\n0.1秒以内",
    "type": "title_top"
  },
  {
    "scene_id": "scene_02",
    "start_sec": 5.39,
    "end_sec": 7.92,
    "text": "Princeton大学\\N「First Impressions」研究\\N（Willis & Todorov, 2006）",
    "type": "source"
  },
  {
    "scene_id": "scene_03",
    "start_sec": 7.92,
    "end_sec": 9.62,
    "text": "人間は他人の顔を見て、",
    "type": "summary"
  },
  {
    "scene_id": "scene_04",
    "start_sec": 9.62,
    "end_sec": 11.33,
    "text": "わずか0.1秒以内に",
    "type": "summary"
  },
  {
    "scene_id": "scene_05",
    "start_sec": 11.33,
    "end_sec": 13.2,
    "text": "「信頼できる／できない」",
    "type": "summary"
  },
  {
    "scene_id": "scene_06",
    "start_sec": 13.2,
    "end_sec": 14.26,
    "text": "を判断している。",
    "type": "summary"
  },
  {
    "scene_id": "scene_07",
    "start_sec": 14.26,
    "end_sec": 14.98,
    "text": "これは",
    "type": "summary"
  },
  {
    "scene_id": "scene_08",
    "start_sec": 14.98,
    "end_sec": 16.56,
    "text": "意識的な評価ではなく、",
    "type": "summary"
  },
  {
    "scene_id": "scene_09",
    "start_sec": 16.56,
    "end_sec": 17.78,
    "text": "脳の潜在的な",
    "type": "summary"
  },
  {
    "scene_id": "scene_10",
    "start_sec": 17.78,
    "end_sec": 19.87,
    "text": "判断メカニズムに基づくと\\Nされる。",
    "type": "summary"
  },
  {
    "scene_id": "scene_11_center",
    "start_sec": 19.87,
    "end_sec": 23.0,
    "text": "“見た目が良い人”は\n無条件に\n好意的に見られる",
    "type": "title_center"
  },
  {
    "scene_id": "scene_11_top",
    "start_sec": 23.0,
    "end_sec": 31.45,
    "text": "“見た目が良い人”は\n無条件に\n好意的に見られる",
    "type": "title_top"
  },
  {
    "scene_id": "scene_11",
    "start_sec": 19.87,
    "end_sec": 23.0,
    "text": "Eagly & Ashmore (1991),\\N\"What is beautiful is good\" 仮説",
    "type": "source"
  },
  {
    "scene_id": "scene_12",
    "start_sec": 23.0,
    "end_sec": 24.66,
    "text": "外見が魅力的な人は、",
    "type": "summary"
  },
  {
    "scene_id": "scene_13",
    "start_sec": 24.66,
    "end_sec": 26.05,
    "text": "性格や知能までも",
    "type": "summary"
  },
  {
    "scene_id": "scene_14",
    "start_sec": 26.05,
    "end_sec": 27.75,
    "text": "高く評価されやすいという",
    "type": "summary"
  },
  {
    "scene_id": "scene_15",
    "start_sec": 27.75,
    "end_sec": 30.02,
    "text": "「ハロー効果」の影響を\\N受けやすい。",
    "type": "summary"
  },
  {
    "scene_id": "scene_16",
    "start_sec": 30.02,
    "end_sec": 31.32,
    "text": "これは見た目だけで",
    "type": "summary"
  },
  {
    "scene_id": "scene_17",
    "start_sec": 31.32,
    "end_sec": 33.2,
    "text": "“総合的に良さそう”と",
    "type": "summary"
  },
  {
    "scene_id": "scene_18",
    "start_sec": 33.2,
    "end_sec": 35.04,
    "text": "判断される心理的バイアス。",
    "type": "summary"
  },
  {
    "scene_id": "scene_19_center",
    "start_sec": 35.04,
    "end_sec": 38.25,
    "text": "顔の対称性が\n“信頼”\nと結びついている",
    "type": "title_center"
  },
  {
    "scene_id": "scene_19_top",
    "start_sec": 38.25,
    "end_sec": 44.14,
    "text": "顔の対称性が\n“信頼”\nと結びついている",
    "type": "title_top"
  },
  {
    "scene_id": "scene_19",
    "start_sec": 35.04,
    "end_sec": 38.25,
    "text": "Harvard大学\\N心理学研究所（2008）",
    "type": "source"
  },
  {
    "scene_id": "scene_20",
    "start_sec": 38.25,
    "end_sec": 40.32,
    "text": "顔の左右対称性が高いほど、",
    "type": "summary"
  },
  {
    "scene_id": "scene_21",
    "start_sec": 40.32,
    "end_sec": 43.35,
    "text": "被験者はその人物を\\N「信頼できる」と",
    "type": "summary"
  },
  {
    "scene_id": "scene_22",
    "start_sec": 43.35,
    "end_sec": 44.82,
    "text": "判断する傾向がある。",
    "type": "summary"
  },
  {
    "scene_id": "scene_23",
    "start_sec": 44.82,
    "end_sec": 46.76,
    "text": "美的評価が\\N社会的信用に",
    "type": "summary"
  },
  {
    "scene_id": "scene_24",
    "start_sec": 46.76,
    "end_sec": 48.94,
    "text": "影響することが\\N実験で示されている。",
    "type": "summary"
  },
  {
    "scene_id": "scene_25_center",
    "start_sec": 48.94,
    "end_sec": 53.42,
    "text": "表情と眼差しだけで\n「好意」か「警戒」かを\n判定",
    "type": "title_center"
  },
  {
    "scene_id": "scene_25_top",
    "start_sec": 53.42,
    "end_sec": 57.09,
    "text": "表情と眼差しだけで\n「好意」か「警戒」かを\n判定",
    "type": "title_top"
  },
  {
    "scene_id": "scene_25",
    "start_sec": 48.94,
    "end_sec": 53.42,
    "text": "Psychological Science\\N（2014）論文",
    "type": "source"
  },
  {
    "scene_id": "scene_26",
    "start_sec": 53.42,
    "end_sec": 55.84,
    "text": "被験者はわずかな表情や\\N目の動きから、",
    "type": "summary"
  },
  {
    "scene_id": "scene_27",
    "start_sec": 55.84,
    "end_sec": 57.78,
    "text": "相手が敵意を持っているかどうかを",
    "type": "summary"
  },
  {
    "scene_id": "scene_28",
    "start_sec": 57.78,
    "end_sec": 58.99,
    "text": "即座に察知する。",
    "type": "summary"
  },
  {
    "scene_id": "scene_29",
    "start_sec": 58.99,
    "end_sec": 60.93,
    "text": "これは進化的に\\N獲得された",
    "type": "summary"
  },
  {
    "scene_id": "scene_30",
    "start_sec": 60.93,
    "end_sec": 63.08,
    "text": "“危険回避”の能力と\\Nされている。",
    "type": "summary"
  },
  {
    "scene_id": "scene_31_center",
    "start_sec": 63.08,
    "end_sec": 67.39,
    "text": "外見が良い人ほど\n“得をする”のは\n経済的にも証明済み",
    "type": "title_center"
  },
  {
    "scene_id": "scene_31_top",
    "start_sec": 67.39,
    "end_sec": 72.53,
    "text": "外見が良い人ほど\n“得をする”のは\n経済的にも証明済み",
    "type": "title_top"
  },
  {
    "scene_id": "scene_31",
    "start_sec": 63.08,
    "end_sec": 67.39,
    "text": "University of Texas\\N「外見と年収」調査（2011）",
    "type": "source"
  },
  {
    "scene_id": "scene_32",
    "start_sec": 67.39,
    "end_sec": 69.13,
    "text": "容姿が平均より良い人は、",
    "type": "summary"
  },
  {
    "scene_id": "scene_33",
    "start_sec": 69.13,
    "end_sec": 70.59,
    "text": "そうでない人に比べて",
    "type": "summary"
  },
  {
    "scene_id": "scene_34",
    "start_sec": 70.59,
    "end_sec": 73.22,
    "text": "平均で5〜10%年収が高い",
    "type": "summary"
  },
  {
    "scene_id": "scene_35",
    "start_sec": 73.22,
    "end_sec": 74.57,
    "text": "傾向があると判明。",
    "type": "summary"
  },
  {
    "scene_id": "scene_36",
    "start_sec": 74.57,
    "end_sec": 76.23,
    "text": "これは単に印象が良い",
    "type": "summary"
  },
  {
    "scene_id": "scene_37",
    "start_sec": 76.23,
    "end_sec": 77.39,
    "text": "という理由だけで",
    "type": "summary"
  },
  {
    "scene_id": "scene_38",
    "start_sec": 77.39,
    "end_sec": 80.13,
    "text": "“待遇差”が発生している\\N証拠である。",
    "type": "summary"
  },
  {
    "scene_id": "scene_39_center",
    "start_sec": 80.13,
    "end_sec": 81.62,
    "text": "美人は攻撃されない",
    "type": "title_center"
  },
  {
    "scene_id": "scene_39_top",
    "start_sec": 81.62,
    "end_sec": 80.1,
    "text": "美人は攻撃されない",
    "type": "title_top"
  },
  {
    "scene_id": "scene_39",
    "start_sec": 80.13,
    "end_sec": 81.62,
    "text": "ハーバード大学・\\N社会心理学研究（2012年）",
    "type": "source"
  },
  {
    "scene_id": "scene_40",
    "start_sec": 81.62,
    "end_sec": 84.19,
    "text": "非難や敵意を受けにくく、\\N結果として",
    "type": "summary"
  },
  {
    "scene_id": "scene_41",
    "start_sec": 84.19,
    "end_sec": 86.01,
    "text": "他人への警戒心が\\N低くなり、",
    "type": "summary"
  },
  {
    "scene_id": "scene_42",
    "start_sec": 86.01,
    "end_sec": 88.49,
    "text": "協調的な性格が\\N育ちやすい傾向がある。",
    "type": "summary"
  },
  {
    "scene_id": "scene_43_center",
    "start_sec": 88.49,
    "end_sec": 92.05,
    "text": "外見で“得している”実感が自己肯定感を形成",
    "type": "title_center"
  },
  {
    "scene_id": "scene_43_top",
    "start_sec": 92.05,
    "end_sec": 90.46,
    "text": "外見で“得している”実感が自己肯定感を形成",
    "type": "title_top"
  },
  {
    "scene_id": "scene_43",
    "start_sec": 88.49,
    "end_sec": 92.05,
    "text": "カリフォルニア大学\\Nロサンゼルス校（UCLA）\\N心理学部・2014年",
    "type": "source"
  },
  {
    "scene_id": "scene_44",
    "start_sec": 92.05,
    "end_sec": 94.57,
    "text": "多く経験した人は、\\N自己肯定感が",
    "type": "summary"
  },
  {
    "scene_id": "scene_45",
    "start_sec": 94.57,
    "end_sec": 97.07,
    "text": "高くなる傾向があり、\\Nその影響で",
    "type": "summary"
  },
  {
    "scene_id": "scene_46",
    "start_sec": 97.07,
    "end_sec": 99.66,
    "text": "対人関係における余裕や\\N寛容性が増す。",
    "type": "summary"
  },
  {
    "scene_id": "scene_47_center",
    "start_sec": 99.66,
    "end_sec": 101.81,
    "text": "魅力度と共感性に正の相関",
    "type": "title_center"
  },
  {
    "scene_id": "scene_47_top",
    "start_sec": 101.81,
    "end_sec": 98.76,
    "text": "魅力度と共感性に正の相関",
    "type": "title_top"
  },
  {
    "scene_id": "scene_47",
    "start_sec": 99.66,
    "end_sec": 101.81,
    "text": "日本心理学会・\\N『心理学研究』第85巻（2014年）",
    "type": "source"
  },
  {
    "scene_id": "scene_48",
    "start_sec": 101.81,
    "end_sec": 103.61,
    "text": "他者の感情を\\Nより正確に",
    "type": "summary"
  },
  {
    "scene_id": "scene_49",
    "start_sec": 103.61,
    "end_sec": 105.28,
    "text": "読み取る能力が\\N高いという",
    "type": "summary"
  },
  {
    "scene_id": "scene_50",
    "start_sec": 105.28,
    "end_sec": 107.56,
    "text": "データがあり、\\N共感性においても",
    "type": "summary"
  },
  {
    "scene_id": "scene_51",
    "start_sec": 107.56,
    "end_sec": 108.96,
    "text": "高いスコアを示した。",
    "type": "summary"
  },
  {
    "scene_id": "scene_52_center",
    "start_sec": 108.96,
    "end_sec": 112.58,
    "text": "見た目の良さは「親切な性格」と連想されやすい",
    "type": "title_center"
  },
  {
    "scene_id": "scene_52_top",
    "start_sec": 112.58,
    "end_sec": 109.79,
    "text": "見た目の良さは「親切な性格」と連想されやすい",
    "type": "title_top"
  },
  {
    "scene_id": "scene_52",
    "start_sec": 108.96,
    "end_sec": 112.58,
    "text": "アメリカ心理学会（APA）・\\N“Halo Effect”研究（2010年）",
    "type": "source"
  },
  {
    "scene_id": "scene_53",
    "start_sec": 112.58,
    "end_sec": 114.6,
    "text": "対して内面も\\n優れているという",
    "type": "summary"
  },
  {
    "scene_id": "scene_54",
    "start_sec": 114.6,
    "end_sec": 117.23,
    "text": "印象（ハロー効果）を\\N抱きやすく、",
    "type": "summary"
  },
  {
    "scene_id": "scene_55",
    "start_sec": 117.23,
    "end_sec": 118.82,
    "text": "それが自己期待の強化と",
    "type": "summary"
  },
  {
    "scene_id": "scene_56",
    "start_sec": 118.82,
    "end_sec": 120.98,
    "text": "性格形成に影響することがある。",
    "type": "summary"
  },
  {
    "scene_id": "scene_57_center",
    "start_sec": 120.98,
    "end_sec": 123.85,
    "text": "美人は「無意味なマウンティング」をされにくい",
    "type": "title_center"
  },
  {
    "scene_id": "scene_57_top",
    "start_sec": 123.85,
    "end_sec": 118.52,
    "text": "美人は「無意味なマウンティング」をされにくい",
    "type": "title_top"
  },
  {
    "scene_id": "scene_57",
    "start_sec": 120.98,
    "end_sec": 123.85,
    "text": "京都大学・\\N人間環境学研究（2017年）",
    "type": "source"
  },
  {
    "scene_id": "scene_58",
    "start_sec": 123.85,
    "end_sec": 126.68,
    "text": "頻度が低く、\\Nそれによるストレス要因が",
    "type": "summary"
  },
  {
    "scene_id": "scene_59",
    "start_sec": 126.68,
    "end_sec": 129.07,
    "text": "減るため、\\N社会的な攻撃性が",
    "type": "summary"
  },
  {
    "scene_id": "scene_60",
    "start_sec": 129.07,
    "end_sec": 130.51,
    "text": "育ちにくい\\N傾向がある。",
    "type": "summary"
  }
]