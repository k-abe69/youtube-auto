[
  {
    "scene_id": "scene_01",
    "start_sec": 0.0,
    "end_sec": 5.39,
    "text": "イケメンの親切は\\N信じられるのに\\N“キモい男の親切”は\\N警戒されるのはなぜ？",
    "type": "main_title"
  },
  {
    "scene_id": "scene_02_center",
    "start_sec": 5.39,
    "end_sec": 7.92,
    "text": "見た目で判断されるのは\n0.1秒以内",
    "type": "title_center"
  },
  {
    "scene_id": "scene_02_top",
    "start_sec": 7.92,
    "end_sec": 17.87,
    "text": "見た目で判断されるのは\n0.1秒以内",
    "type": "title_top"
  },
  {
    "scene_id": "scene_02",
    "start_sec": 5.39,
    "end_sec": 7.92,
    "text": "Princeton大学\\N「First Impressions」研究\\N（Willis & Todorov, 2006）",
    "type": "source"
  },
  {
    "scene_id": "scene_03",
    "start_sec": 7.92,
    "end_sec": 9.62,
    "text": "人間は他人の顔を見て、\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_04",
    "start_sec": 9.62,
    "end_sec": 11.33,
    "text": "わずか0.1秒以内に\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_05",
    "start_sec": 11.33,
    "end_sec": 13.2,
    "text": "「信頼で\\Nきる／できない」",
    "type": "summary"
  },
  {
    "scene_id": "scene_06",
    "start_sec": 13.2,
    "end_sec": 14.26,
    "text": "を判断している。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_07",
    "start_sec": 14.26,
    "end_sec": 14.98,
    "text": "これは\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_08",
    "start_sec": 14.98,
    "end_sec": 16.56,
    "text": "意識的な評価ではなく、\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_09",
    "start_sec": 16.56,
    "end_sec": 17.78,
    "text": "脳の\\N潜在的な",
    "type": "summary"
  },
  {
    "scene_id": "scene_10",
    "start_sec": 17.78,
    "end_sec": 19.87,
    "text": "判断メカニズムに基づくとされる。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_11_center",
    "start_sec": 19.87,
    "end_sec": 23.0,
    "text": "“見た目が良い人”は\n無条件に\n好意的に見られる",
    "type": "title_center"
  },
  {
    "scene_id": "scene_11_top",
    "start_sec": 23.0,
    "end_sec": 31.45,
    "text": "“見た目が良い人”は\n無条件に\n好意的に見られる",
    "type": "title_top"
  },
  {
    "scene_id": "scene_11",
    "start_sec": 19.87,
    "end_sec": 23.0,
    "text": "Eagly & Ashmore (1991),\\N\"What is beautiful is good\" 仮説",
    "type": "source"
  },
  {
    "scene_id": "scene_12",
    "start_sec": 23.0,
    "end_sec": 24.66,
    "text": "外見が魅力的な人は、\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_13",
    "start_sec": 24.66,
    "end_sec": 26.05,
    "text": "性格や知能まで\\Nも",
    "type": "summary"
  },
  {
    "scene_id": "scene_14",
    "start_sec": 26.05,
    "end_sec": 27.75,
    "text": "高く評価されやすいと\\Nいう",
    "type": "summary"
  },
  {
    "scene_id": "scene_15",
    "start_sec": 27.75,
    "end_sec": 30.02,
    "text": "「ハロー効果」の影響を受けやすい。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_16",
    "start_sec": 30.02,
    "end_sec": 31.32,
    "text": "これは\\N見た目だけで",
    "type": "summary"
  },
  {
    "scene_id": "scene_17",
    "start_sec": 31.32,
    "end_sec": 33.2,
    "text": "“総合的に\\N良さそう”と",
    "type": "summary"
  },
  {
    "scene_id": "scene_18",
    "start_sec": 33.2,
    "end_sec": 35.04,
    "text": "判断される心理的バイアス。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_19_center",
    "start_sec": 35.04,
    "end_sec": 38.25,
    "text": "顔の対称性が\n“信頼”\nと結びついている",
    "type": "title_center"
  },
  {
    "scene_id": "scene_19_top",
    "start_sec": 38.25,
    "end_sec": 44.14,
    "text": "顔の対称性が\n“信頼”\nと結びついている",
    "type": "title_top"
  },
  {
    "scene_id": "scene_19",
    "start_sec": 35.04,
    "end_sec": 38.25,
    "text": "Harvard大学\\N心理学研究所（2008）",
    "type": "source"
  },
  {
    "scene_id": "scene_20",
    "start_sec": 38.25,
    "end_sec": 40.32,
    "text": "顔の左右対称性が高いほど、\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_21",
    "start_sec": 40.32,
    "end_sec": 43.35,
    "text": "被験者は\\Nその人物を「信頼できる」と",
    "type": "summary"
  },
  {
    "scene_id": "scene_22",
    "start_sec": 43.35,
    "end_sec": 44.82,
    "text": "判断する傾向がある。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_23",
    "start_sec": 44.82,
    "end_sec": 46.76,
    "text": "美的評価が\\N社会的信用に",
    "type": "summary"
  },
  {
    "scene_id": "scene_24",
    "start_sec": 46.76,
    "end_sec": 48.94,
    "text": "影響することが実験で示されている。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_25_center",
    "start_sec": 48.94,
    "end_sec": 53.42,
    "text": "表情と眼差しだけで\n「好意」か「警戒」かを\n判定",
    "type": "title_center"
  },
  {
    "scene_id": "scene_25_top",
    "start_sec": 53.42,
    "end_sec": 57.09,
    "text": "表情と眼差しだけで\n「好意」か「警戒」かを\n判定",
    "type": "title_top"
  },
  {
    "scene_id": "scene_25",
    "start_sec": 48.94,
    "end_sec": 53.42,
    "text": "Psychological Science\\N（2014）論文",
    "type": "source"
  },
  {
    "scene_id": "scene_26",
    "start_sec": 53.42,
    "end_sec": 55.84,
    "text": "被験者はわずかな表情や目の動きから、\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_27",
    "start_sec": 55.84,
    "end_sec": 57.78,
    "text": "相手が\\N敵意を持っているかどうかを",
    "type": "summary"
  },
  {
    "scene_id": "scene_28",
    "start_sec": 57.78,
    "end_sec": 58.99,
    "text": "即座に察知する。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_29",
    "start_sec": 58.99,
    "end_sec": 60.93,
    "text": "これは\\N進化的に獲得された",
    "type": "summary"
  },
  {
    "scene_id": "scene_30",
    "start_sec": 60.93,
    "end_sec": 63.08,
    "text": "“危険回避”の能力とされている。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_31_center",
    "start_sec": 63.08,
    "end_sec": 67.39,
    "text": "外見が良い人ほど\n“得をする”のは\n経済的にも証明済み",
    "type": "title_center"
  },
  {
    "scene_id": "scene_31_top",
    "start_sec": 67.39,
    "end_sec": 72.53,
    "text": "外見が良い人ほど\n“得をする”のは\n経済的にも証明済み",
    "type": "title_top"
  },
  {
    "scene_id": "scene_31",
    "start_sec": 63.08,
    "end_sec": 67.39,
    "text": "University of Texas\\N「外見と年収」調査（2011）",
    "type": "source"
  },
  {
    "scene_id": "scene_32",
    "start_sec": 67.39,
    "end_sec": 69.13,
    "text": "容姿が平均より良い人は、\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_33",
    "start_sec": 69.13,
    "end_sec": 70.59,
    "text": "そうでない人に\\N比べて",
    "type": "summary"
  },
  {
    "scene_id": "scene_34",
    "start_sec": 70.59,
    "end_sec": 73.22,
    "text": "平均で5〜10%年収が\\N高い",
    "type": "summary"
  },
  {
    "scene_id": "scene_35",
    "start_sec": 73.22,
    "end_sec": 74.57,
    "text": "傾向があると判明。\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_36",
    "start_sec": 74.57,
    "end_sec": 76.23,
    "text": "これは単に印象が\\N良い",
    "type": "summary"
  },
  {
    "scene_id": "scene_37",
    "start_sec": 76.23,
    "end_sec": 77.39,
    "text": "という理由だけで\\N",
    "type": "summary"
  },
  {
    "scene_id": "scene_38",
    "start_sec": 77.39,
    "end_sec": 80.13,
    "text": "“待遇差”が発生している証拠である。\\N",
    "type": "summary"
  }
]