[
  {
    "scene_id": "scene_01",
    "type": "main_title",
    "text": "イケメンの親切は信じられるのに、\n“キモい男の親切”は\n警戒されるのはなぜ？",
    "start_sec": 0.0,
    "duration": 5.19
  },
  {
    "scene_id": "scene_02",
    "type": "title",
    "text": "見た目で判断されるのは\n0.1秒以内",
    "start_sec": 5.19,
    "duration": 2.33
  },
  {
    "scene_id": "scene_02",
    "type": "source",
    "text": "Princeton大学「First Impressions」研究（Willis & Todorov, 2006）",
    "start_sec": 5.19,
    "duration": 2.33
  },
  {
    "scene_id": "scene_03",
    "type": "summary",
    "text": "人間は他人の顔を見て、",
    "start_sec": 7.52,
    "duration": 1.5
  },
  {
    "scene_id": "scene_04",
    "type": "summary",
    "text": "わずか0.1秒以内に",
    "start_sec": 9.02,
    "duration": 1.5
  },
  {
    "scene_id": "scene_05",
    "type": "summary",
    "text": "「信頼できる／できない」",
    "start_sec": 10.53,
    "duration": 1.67
  },
  {
    "scene_id": "scene_06",
    "type": "summary",
    "text": "を判断している。",
    "start_sec": 12.2,
    "duration": 0.85
  },
  {
    "scene_id": "scene_07",
    "type": "summary",
    "text": "これは意識的な評価ではなく、",
    "start_sec": 13.06,
    "duration": 1.67
  },
  {
    "scene_id": "scene_08",
    "type": "summary",
    "text": "脳の潜在的な判断メカニズムに",
    "start_sec": 14.73,
    "duration": 1.99
  },
  {
    "scene_id": "scene_09",
    "type": "summary",
    "text": "基づくとされる。",
    "start_sec": 16.73,
    "duration": 0.93
  },
  {
    "scene_id": "scene_10",
    "type": "title",
    "text": "“見た目が良い人”は\n無条件に好意的に見られる",
    "start_sec": 17.65,
    "duration": 2.93
  },
  {
    "scene_id": "scene_10",
    "type": "source",
    "text": "Eagly & Ashmore (1991), \"What is beautiful is good\" 仮説",
    "start_sec": 17.65,
    "duration": 2.93
  },
  {
    "scene_id": "scene_11",
    "type": "summary",
    "text": "外見が魅力的な人は、",
    "start_sec": 20.59,
    "duration": 1.46
  },
  {
    "scene_id": "scene_12",
    "type": "summary",
    "text": "性格や知能までも高く評価されやすいという",
    "start_sec": 22.05,
    "duration": 2.47
  },
  {
    "scene_id": "scene_13",
    "type": "summary",
    "text": "「ハロー効果」の影響を受けやすい。",
    "start_sec": 24.52,
    "duration": 2.07
  },
  {
    "scene_id": "scene_14",
    "type": "summary",
    "text": "これは見た目だけで“総合的に良さそう”と",
    "start_sec": 26.59,
    "duration": 2.87
  },
  {
    "scene_id": "scene_15",
    "type": "summary",
    "text": "判断される心理的バイアス。",
    "start_sec": 29.46,
    "duration": 1.64
  },
  {
    "scene_id": "scene_16",
    "type": "title",
    "text": "顔の対称性が“信頼”と結びついている",
    "start_sec": 31.1,
    "duration": 3.01
  },
  {
    "scene_id": "scene_16",
    "type": "source",
    "text": "Harvard大学心理学研究所（2008）",
    "start_sec": 31.1,
    "duration": 3.01
  },
  {
    "scene_id": "scene_17",
    "type": "summary",
    "text": "顔の左右対称性が高いほど、",
    "start_sec": 34.11,
    "duration": 1.87
  },
  {
    "scene_id": "scene_18",
    "type": "summary",
    "text": "被験者はその人物を「信頼できる」と",
    "start_sec": 35.98,
    "duration": 2.84
  },
  {
    "scene_id": "scene_19",
    "type": "summary",
    "text": "判断する傾向がある。",
    "start_sec": 38.82,
    "duration": 1.27
  },
  {
    "scene_id": "scene_20",
    "type": "summary",
    "text": "美的評価が社会的信用に",
    "start_sec": 40.09,
    "duration": 1.74
  },
  {
    "scene_id": "scene_21",
    "type": "summary",
    "text": "影響することが実験で示されている。",
    "start_sec": 41.82,
    "duration": 1.97
  },
  {
    "scene_id": "scene_22",
    "type": "title",
    "text": "表情と眼差しだけで「好意」か「警戒」かを判定",
    "start_sec": 43.8,
    "duration": 4.29
  },
  {
    "scene_id": "scene_22",
    "type": "source",
    "text": "Psychological Science（2014）論文",
    "start_sec": 43.8,
    "duration": 4.29
  },
  {
    "scene_id": "scene_23",
    "type": "summary",
    "text": "被験者はわずかな表情や目の動きから、",
    "start_sec": 48.09,
    "duration": 2.22
  },
  {
    "scene_id": "scene_24",
    "type": "summary",
    "text": "相手が敵意を持っているかどうかを",
    "start_sec": 50.3,
    "duration": 1.74
  },
  {
    "scene_id": "scene_25",
    "type": "summary",
    "text": "即座に察知する。",
    "start_sec": 52.04,
    "duration": 1.01
  },
  {
    "scene_id": "scene_26",
    "type": "summary",
    "text": "これは進化的に獲得された",
    "start_sec": 53.06,
    "duration": 1.74
  },
  {
    "scene_id": "scene_27",
    "type": "summary",
    "text": "“危険回避”の能力とされている。",
    "start_sec": 54.79,
    "duration": 1.95
  },
  {
    "scene_id": "scene_28",
    "type": "title",
    "text": "外見が良い人ほど“得をする”のは経済的にも証明済み",
    "start_sec": 56.75,
    "duration": 4.11
  },
  {
    "scene_id": "scene_28",
    "type": "source",
    "text": "University of Texas「外見と年収」調査（2011）",
    "start_sec": 56.75,
    "duration": 4.11
  },
  {
    "scene_id": "scene_29",
    "type": "summary",
    "text": "容姿が平均より良い人は、",
    "start_sec": 60.85,
    "duration": 1.54
  },
  {
    "scene_id": "scene_30",
    "type": "summary",
    "text": "そうでない人に比べて",
    "start_sec": 62.39,
    "duration": 1.26
  },
  {
    "scene_id": "scene_31",
    "type": "summary",
    "text": "平均で5〜10%年収が高い傾向があると判明。",
    "start_sec": 63.65,
    "duration": 3.35
  },
  {
    "scene_id": "scene_32",
    "type": "summary",
    "text": "これは単に印象が良いという理由だけで",
    "start_sec": 67.0,
    "duration": 2.2
  },
  {
    "scene_id": "scene_33",
    "type": "summary",
    "text": "“待遇差”が発生している証拠である。",
    "start_sec": 69.19,
    "duration": 2.54
  }
]