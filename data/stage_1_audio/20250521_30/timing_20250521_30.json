[
  {
    "scene_id": "scene_01",
    "start_sec": 0.0,
    "duration": 5.19,
    "text": "イケメンの親切は\n信じられるのに\n“キモい男の親切”は\n警戒されるのはなぜ？",
    "type": "main_title"
  },
  {
    "scene_id": "scene_02",
    "start_sec": 5.19,
    "duration": 2.33,
    "text": "見た目で判断されるのは\n0.1秒以内",
    "type": "title"
  },
  {
    "scene_id": "scene_03",
    "start_sec": 7.52,
    "duration": 1.5,
    "text": "人間は他人の顔を見て、",
    "type": "summary"
  },
  {
    "scene_id": "scene_04",
    "start_sec": 9.02,
    "duration": 1.5,
    "text": "わずか0.1秒以内に",
    "type": "summary"
  },
  {
    "scene_id": "scene_05",
    "start_sec": 10.53,
    "duration": 1.67,
    "text": "「信頼できる／できない」",
    "type": "summary"
  },
  {
    "scene_id": "scene_06",
    "start_sec": 12.2,
    "duration": 0.85,
    "text": "を判断している。",
    "type": "summary"
  },
  {
    "scene_id": "scene_07",
    "start_sec": 13.06,
    "duration": 0.52,
    "text": "これは",
    "type": "summary"
  },
  {
    "scene_id": "scene_08",
    "start_sec": 13.58,
    "duration": 1.39,
    "text": "意識的な評価ではなく、",
    "type": "summary"
  },
  {
    "scene_id": "scene_09",
    "start_sec": 14.97,
    "duration": 1.01,
    "text": "脳の潜在的な",
    "type": "summary"
  },
  {
    "scene_id": "scene_10",
    "start_sec": 15.98,
    "duration": 1.89,
    "text": "判断メカニズムに基づくとされる。",
    "type": "summary"
  },
  {
    "scene_id": "scene_11",
    "start_sec": 17.87,
    "duration": 2.93,
    "text": "“見た目が良い人”は\n無条件に\n好意的に見られる",
    "type": "title"
  },
  {
    "scene_id": "scene_12",
    "start_sec": 20.8,
    "duration": 1.46,
    "text": "外見が魅力的な人は、",
    "type": "summary"
  },
  {
    "scene_id": "scene_13",
    "start_sec": 22.26,
    "duration": 1.19,
    "text": "性格や知能までも",
    "type": "summary"
  },
  {
    "scene_id": "scene_14",
    "start_sec": 23.46,
    "duration": 1.49,
    "text": "高く評価されやすいという",
    "type": "summary"
  },
  {
    "scene_id": "scene_15",
    "start_sec": 24.95,
    "duration": 2.07,
    "text": "「ハロー効果」の影響を受けやすい。",
    "type": "summary"
  },
  {
    "scene_id": "scene_16",
    "start_sec": 27.02,
    "duration": 1.1,
    "text": "これは見た目だけで",
    "type": "summary"
  },
  {
    "scene_id": "scene_17",
    "start_sec": 28.12,
    "duration": 1.69,
    "text": "“総合的に良さそう”と",
    "type": "summary"
  },
  {
    "scene_id": "scene_18",
    "start_sec": 29.8,
    "duration": 1.64,
    "text": "判断される心理的バイアス。",
    "type": "summary"
  },
  {
    "scene_id": "scene_19",
    "start_sec": 31.45,
    "duration": 3.01,
    "text": "顔の対称性が\n“信頼”\nと結びついている",
    "type": "title"
  },
  {
    "scene_id": "scene_20",
    "start_sec": 34.45,
    "duration": 1.87,
    "text": "顔の左右対称性が高いほど、",
    "type": "summary"
  },
  {
    "scene_id": "scene_21",
    "start_sec": 36.32,
    "duration": 2.84,
    "text": "被験者はその人物を「信頼できる」と",
    "type": "summary"
  },
  {
    "scene_id": "scene_22",
    "start_sec": 39.16,
    "duration": 1.27,
    "text": "判断する傾向がある。",
    "type": "summary"
  },
  {
    "scene_id": "scene_23",
    "start_sec": 40.43,
    "duration": 1.74,
    "text": "美的評価が社会的信用に",
    "type": "summary"
  },
  {
    "scene_id": "scene_24",
    "start_sec": 42.17,
    "duration": 1.97,
    "text": "影響することが実験で示されている。",
    "type": "summary"
  },
  {
    "scene_id": "scene_25",
    "start_sec": 44.14,
    "duration": 4.29,
    "text": "表情と眼差しだけで\n「好意」か「警戒」かを\n判定",
    "type": "title"
  },
  {
    "scene_id": "scene_26",
    "start_sec": 48.43,
    "duration": 2.22,
    "text": "被験者はわずかな表情や目の動きから、",
    "type": "summary"
  },
  {
    "scene_id": "scene_27",
    "start_sec": 50.65,
    "duration": 1.74,
    "text": "相手が敵意を持っているかどうかを",
    "type": "summary"
  },
  {
    "scene_id": "scene_28",
    "start_sec": 52.38,
    "duration": 1.01,
    "text": "即座に察知する。",
    "type": "summary"
  },
  {
    "scene_id": "scene_29",
    "start_sec": 53.4,
    "duration": 1.74,
    "text": "これは進化的に獲得された",
    "type": "summary"
  },
  {
    "scene_id": "scene_30",
    "start_sec": 55.14,
    "duration": 1.95,
    "text": "“危険回避”の能力とされている。",
    "type": "summary"
  },
  {
    "scene_id": "scene_31",
    "start_sec": 57.09,
    "duration": 4.11,
    "text": "外見が良い人ほど\n“得をする”のは\n経済的にも証明済み",
    "type": "title"
  },
  {
    "scene_id": "scene_32",
    "start_sec": 61.19,
    "duration": 1.54,
    "text": "容姿が平均より良い人は、",
    "type": "summary"
  },
  {
    "scene_id": "scene_33",
    "start_sec": 62.73,
    "duration": 1.26,
    "text": "そうでない人に比べて",
    "type": "summary"
  },
  {
    "scene_id": "scene_34",
    "start_sec": 63.99,
    "duration": 2.43,
    "text": "平均で5〜10%年収が高い",
    "type": "summary"
  },
  {
    "scene_id": "scene_35",
    "start_sec": 66.42,
    "duration": 1.15,
    "text": "傾向があると判明。",
    "type": "summary"
  },
  {
    "scene_id": "scene_36",
    "start_sec": 67.57,
    "duration": 1.46,
    "text": "これは単に印象が良い",
    "type": "summary"
  },
  {
    "scene_id": "scene_37",
    "start_sec": 69.03,
    "duration": 0.96,
    "text": "という理由だけで",
    "type": "summary"
  },
  {
    "scene_id": "scene_38",
    "start_sec": 69.99,
    "duration": 2.54,
    "text": "“待遇差”が発生している証拠である。",
    "type": "summary"
  },
  {
    "scene_id": "scene_39",
    "start_sec": 72.53,
    "duration": 1.29,
    "text": "美人は攻撃されない",
    "type": "title"
  },
  {
    "scene_id": "scene_40",
    "start_sec": 73.82,
    "duration": 2.37,
    "text": "非難や敵意を受けにくく、結果として",
    "type": "summary"
  },
  {
    "scene_id": "scene_41",
    "start_sec": 76.19,
    "duration": 1.62,
    "text": "他人への警戒心が低くなり、",
    "type": "summary"
  },
  {
    "scene_id": "scene_42",
    "start_sec": 77.81,
    "duration": 2.28,
    "text": "協調的な性格が育ちやすい傾向がある。",
    "type": "summary"
  },
  {
    "scene_id": "scene_43",
    "start_sec": 80.1,
    "duration": 3.36,
    "text": "外見で“得している”実感が自己肯定感を形成",
    "type": "title"
  },
  {
    "scene_id": "scene_44",
    "start_sec": 83.46,
    "duration": 2.31,
    "text": "多く経験した人は、自己肯定感が",
    "type": "summary"
  },
  {
    "scene_id": "scene_45",
    "start_sec": 85.77,
    "duration": 2.3,
    "text": "高くなる傾向があり、その影響で",
    "type": "summary"
  },
  {
    "scene_id": "scene_46",
    "start_sec": 88.07,
    "duration": 2.39,
    "text": "対人関係における余裕や寛容性が増す。",
    "type": "summary"
  },
  {
    "scene_id": "scene_47",
    "start_sec": 90.46,
    "duration": 1.95,
    "text": "魅力度と共感性に正の相関",
    "type": "title"
  },
  {
    "scene_id": "scene_48",
    "start_sec": 92.42,
    "duration": 1.6,
    "text": "他者の感情をより正確に",
    "type": "summary"
  },
  {
    "scene_id": "scene_49",
    "start_sec": 94.02,
    "duration": 1.47,
    "text": "読み取る能力が高いという",
    "type": "summary"
  },
  {
    "scene_id": "scene_50",
    "start_sec": 95.49,
    "duration": 2.08,
    "text": "データがあり、共感性においても",
    "type": "summary"
  },
  {
    "scene_id": "scene_51",
    "start_sec": 97.57,
    "duration": 1.19,
    "text": "高いスコアを示した。",
    "type": "summary"
  },
  {
    "scene_id": "scene_52",
    "start_sec": 98.76,
    "duration": 3.42,
    "text": "見た目の良さは「親切な性格」と連想されやすい",
    "type": "title"
  },
  {
    "scene_id": "scene_53",
    "start_sec": 102.19,
    "duration": 1.82,
    "text": "対して内面も優れているという",
    "type": "summary"
  },
  {
    "scene_id": "scene_54",
    "start_sec": 104.01,
    "duration": 2.42,
    "text": "印象（ハロー効果）を抱きやすく、",
    "type": "summary"
  },
  {
    "scene_id": "scene_55",
    "start_sec": 106.43,
    "duration": 1.4,
    "text": "それが自己期待の強化と",
    "type": "summary"
  },
  {
    "scene_id": "scene_56",
    "start_sec": 107.83,
    "duration": 1.96,
    "text": "性格形成に影響することがある。",
    "type": "summary"
  },
  {
    "scene_id": "scene_57",
    "start_sec": 109.79,
    "duration": 2.67,
    "text": "美人は「無意味なマウンティング」をされにくい",
    "type": "title"
  },
  {
    "scene_id": "scene_58",
    "start_sec": 112.46,
    "duration": 2.62,
    "text": "頻度が低く、それによるストレス要因が",
    "type": "summary"
  },
  {
    "scene_id": "scene_59",
    "start_sec": 115.08,
    "duration": 2.2,
    "text": "減るため、社会的な攻撃性が",
    "type": "summary"
  },
  {
    "scene_id": "scene_60",
    "start_sec": 117.28,
    "duration": 1.24,
    "text": "育ちにくい傾向がある。",
    "type": "summary"
  }
]