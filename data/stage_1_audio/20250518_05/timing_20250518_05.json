[
  {
    "scene_id": "scene_01",
    "start_sec": 0.0,
    "duration": 5.19,
    "text": "イケメンの親切は信じられるのに、“キモい男の親切”は警戒されるのはなぜ？",
    "type": "unknown"
  },
  {
    "scene_id": "scene_02",
    "start_sec": 5.19,
    "duration": 2.33,
    "text": "見た目で判断されるのは0.1秒以内",
    "type": "unknown"
  },
  {
    "scene_id": "scene_03",
    "start_sec": 7.52,
    "duration": 1.5,
    "text": "人間は他人の顔を見て、",
    "type": "unknown"
  },
  {
    "scene_id": "scene_04",
    "start_sec": 9.02,
    "duration": 3.3,
    "text": "わずか0.1秒以内に「信頼できる／できない」",
    "type": "unknown"
  },
  {
    "scene_id": "scene_05",
    "start_sec": 12.32,
    "duration": 0.85,
    "text": "を判断している。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_06",
    "start_sec": 13.17,
    "duration": 1.67,
    "text": "これは意識的な評価ではなく、",
    "type": "unknown"
  },
  {
    "scene_id": "scene_07",
    "start_sec": 14.85,
    "duration": 1.99,
    "text": "脳の潜在的な判断メカニズムに",
    "type": "unknown"
  },
  {
    "scene_id": "scene_08",
    "start_sec": 16.84,
    "duration": 0.93,
    "text": "基づくとされる。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_09",
    "start_sec": 17.77,
    "duration": 2.93,
    "text": "“見た目が良い人”は無条件に好意的に見られる",
    "type": "unknown"
  },
  {
    "scene_id": "scene_10",
    "start_sec": 20.7,
    "duration": 1.46,
    "text": "外見が魅力的な人は、",
    "type": "unknown"
  },
  {
    "scene_id": "scene_11",
    "start_sec": 22.17,
    "duration": 2.47,
    "text": "性格や知能までも高く評価されやすいという",
    "type": "unknown"
  },
  {
    "scene_id": "scene_12",
    "start_sec": 24.64,
    "duration": 2.07,
    "text": "「ハロー効果」の影響を受けやすい。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_13",
    "start_sec": 26.71,
    "duration": 2.87,
    "text": "これは見た目だけで“総合的に良さそう”と",
    "type": "unknown"
  },
  {
    "scene_id": "scene_14",
    "start_sec": 29.58,
    "duration": 1.64,
    "text": "判断される心理的バイアス。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_15",
    "start_sec": 31.22,
    "duration": 3.01,
    "text": "顔の対称性が“信頼”と結びついている",
    "type": "unknown"
  },
  {
    "scene_id": "scene_16",
    "start_sec": 34.23,
    "duration": 1.87,
    "text": "顔の左右対称性が高いほど、",
    "type": "unknown"
  },
  {
    "scene_id": "scene_17",
    "start_sec": 36.1,
    "duration": 2.84,
    "text": "被験者はその人物を「信頼できる」と",
    "type": "unknown"
  },
  {
    "scene_id": "scene_18",
    "start_sec": 38.93,
    "duration": 1.27,
    "text": "判断する傾向がある。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_19",
    "start_sec": 40.2,
    "duration": 1.74,
    "text": "美的評価が社会的信用に",
    "type": "unknown"
  },
  {
    "scene_id": "scene_20",
    "start_sec": 41.94,
    "duration": 1.97,
    "text": "影響することが実験で示されている。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_21",
    "start_sec": 43.91,
    "duration": 4.29,
    "text": "表情と眼差しだけで「好意」か「警戒」かを判定",
    "type": "unknown"
  },
  {
    "scene_id": "scene_22",
    "start_sec": 48.2,
    "duration": 2.22,
    "text": "被験者はわずかな表情や目の動きから、",
    "type": "unknown"
  },
  {
    "scene_id": "scene_23",
    "start_sec": 50.42,
    "duration": 1.74,
    "text": "相手が敵意を持っているかどうかを",
    "type": "unknown"
  },
  {
    "scene_id": "scene_24",
    "start_sec": 52.16,
    "duration": 1.01,
    "text": "即座に察知する。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_25",
    "start_sec": 53.17,
    "duration": 1.74,
    "text": "これは進化的に獲得された",
    "type": "unknown"
  },
  {
    "scene_id": "scene_26",
    "start_sec": 54.91,
    "duration": 1.95,
    "text": "“危険回避”の能力とされている。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_27",
    "start_sec": 56.86,
    "duration": 4.11,
    "text": "外見が良い人ほど“得をする”のは経済的にも証明済み",
    "type": "unknown"
  },
  {
    "scene_id": "scene_28",
    "start_sec": 60.97,
    "duration": 1.54,
    "text": "容姿が平均より良い人は、",
    "type": "unknown"
  },
  {
    "scene_id": "scene_29",
    "start_sec": 62.51,
    "duration": 1.26,
    "text": "そうでない人に比べて",
    "type": "unknown"
  },
  {
    "scene_id": "scene_30",
    "start_sec": 63.77,
    "duration": 3.35,
    "text": "平均で5〜10%年収が高い傾向があると判明。",
    "type": "unknown"
  },
  {
    "scene_id": "scene_31",
    "start_sec": 67.11,
    "duration": 2.2,
    "text": "これは単に印象が良いという理由だけで",
    "type": "unknown"
  },
  {
    "scene_id": "scene_32",
    "start_sec": 69.31,
    "duration": 2.54,
    "text": "“待遇差”が発生している証拠である。",
    "type": "unknown"
  }
]